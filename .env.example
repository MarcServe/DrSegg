# Copy to ".env.local" and fill in values. Never commit .env.local.

# Supabase (required for auth + data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Alternative name supported by the app:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# OpenAI — assessments, vision, embeddings (optional but needed for LLM + vector RAG)
OPENAI_API_KEY=

# Anthropic — fallback when OpenAI fails or returns invalid JSON (optional)
ANTHROPIC_API_KEY=
# Optional override (defaults to claude-3-5-sonnet-20241022)
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Set to "false" to disable Claude fallback even if ANTHROPIC_API_KEY is set
# AI_FALLBACK_ENABLED=true
